# Default: normalize all text files to LF in git
* text=auto eol=lf

# Windows scripts
*.bat eol=crlf
*.cmd eol=crlf
*.ps1 eol=crlf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.mp3 binary
*.ttf binary
*.woff binary
*.woff2 binary
*.webp binary
*.pdf binary
*.zip binary
